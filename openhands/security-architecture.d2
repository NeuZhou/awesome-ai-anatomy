direction: down

action: "Agent Action" {
  style.fill: "#374151"
  style.font-color: "#fff"
  label: "Agent Action\n(CmdRun / FileEdit / Browse / ...)"
}

analyzer: "SecurityAnalyzer (base class)" {
  style.fill: "#faf5ff"
  style.stroke: "#7c3aed"

  method: "security_risk(action)" {
    style.fill: "#7c3aed"
    style.font-color: "#fff"
    label: "security_risk(action)\n→ ActionSecurityRisk"
  }
}

grayswan: "GraySwan Analyzer (208 lines)" {
  style.fill: "#fdf4ff"
  style.stroke: "#a855f7"

  api: "Cygnal API" {
    style.fill: "#a855f7"
    style.font-color: "#fff"
    label: "Cygnal API\n(external ML service)"
  }
  convert: "Convert events → OpenAI format"
  threshold: "Configurable thresholds" {
    label: "LOW < 0.3 · MEDIUM < 0.7 · HIGH < 1.0"
  }
  env: "Requires: GRAYSWAN_API_KEY" {
    style.fill: "#fecaca"
  }

  convert -> api -> threshold
}

invariant: "Invariant Analyzer (133 lines)" {
  style.fill: "#f0f4ff"
  style.stroke: "#2563eb"

  client: "InvariantClient" {
    style.fill: "#2563eb"
    style.font-color: "#fff"
    label: "InvariantClient\n(policy engine)"
  }
  policy: "User-defined policies" {
    label: "User-defined policies\n(what agent can/cannot do)"
  }
  trace: "Event trace history"
  confirm: "Ask user confirmation" {
    label: "Policy violation →\nask user for confirmation"
    style.fill: "#fde68a"
  }

  client -> policy
  client -> trace
  policy -> confirm: "violation detected" {style.stroke-dash: 3}
}

llm_risk: "LLM Risk Analyzer (48 lines)" {
  style.fill: "#ecfdf5"
  style.stroke: "#059669"

  self_eval: "Self-evaluation" {
    style.fill: "#059669"
    style.font-color: "#fff"
    label: "Same LLM evaluates\nits own action risk"
  }
  note: "Lightest approach" {
    label: "Zero external dependencies\nWeakest guarantee"
    style.fill: "#fecaca"
  }
}

risk: "ActionSecurityRisk" {
  style.fill: "#fef2f2"
  style.stroke: "#dc2626"

  low: "LOW → proceed" {style.fill: "#bbf7d0"}
  medium: "MEDIUM → log warning" {style.fill: "#fde68a"}
  high: "HIGH → block or ask" {style.fill: "#fca5a5"}
}

action -> analyzer.method
analyzer.method -> grayswan: "Option 1: External ML"
analyzer.method -> invariant: "Option 2: Policy rules"
analyzer.method -> llm_risk: "Option 3: Self-eval"
grayswan.threshold -> risk
invariant.client -> risk
llm_risk.self_eval -> risk
