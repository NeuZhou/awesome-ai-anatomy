direction: down

input: "Event History" {
  style.fill: "#374151"
  style.font-color: "#fff"
  label: "Event History\n(Actions + Observations)"
}

rule_based: "Rule-Based Condensers (fast, no LLM)" {
  style.fill: "#f0f4ff"
  style.stroke: "#2563eb"

  noop: "NoOpCondenser (22 lines)" {
    label: "NoOpCondenser\nPass-through"
  }
  recent: "RecentEventsCondenser (31 lines)" {
    label: "RecentEventsCondenser\nKeep last N events"
  }
  obs_mask: "ObservationMaskingCondenser (39 lines)" {
    label: "ObservationMaskingCondenser\nReplace content → placeholders"
  }
  browser: "BrowserOutputCondenser (49 lines)" {
    label: "BrowserOutputCondenser\nClean verbose browser output"
  }
}

statistical: "Statistical Condensers (probabilistic)" {
  style.fill: "#fffbeb"
  style.stroke: "#d97706"

  amortized: "AmortizedForgettingCondenser (69 lines)" {
    style.fill: "#d97706"
    style.font-color: "#fff"
    label: "AmortizedForgettingCondenser ★\nExponential decay probability\nOlder events more likely to drop"
  }
  conv_window: "ConversationWindowCondenser (188 lines)" {
    label: "ConversationWindowCondenser\nSliding window\nConfigurable keep-first/keep-last"
  }
}

llm_powered: "LLM-Powered Condensers (expensive, smart)" {
  style.fill: "#fdf4ff"
  style.stroke: "#a855f7"

  attention: "LLMAttentionCondenser (140 lines)" {
    label: "LLMAttentionCondenser\nLLM scores importance\nKeeps high-scoring events"
  }
  summarize: "LLMSummarizingCondenser (182 lines)" {
    label: "LLMSummarizingCondenser\nLLM generates summary\nReplaces entire history"
  }
  structured: "StructuredSummaryCondenser (329 lines)" {
    style.fill: "#a855f7"
    style.font-color: "#fff"
    label: "StructuredSummaryCondenser ★\nTask progress tracking\nMost sophisticated strategy"
  }
}

pipeline: "Pipeline Combinator (50 lines)" {
  style.fill: "#16a34a"
  style.font-color: "#fff"
  label: "Pipeline Combinator\nChain any N condensers in sequence"
}

output: "View → LLM" {
  style.fill: "#059669"
  style.font-color: "#fff"
  label: "View (condensed events)\n→ LLM context window"
}

condensation: "Condensation Event" {
  style.fill: "#bbf7d0"
  label: "Condensation Event\n→ appended to EventStream\n(auditable trail of compression)"
}

input -> rule_based
input -> statistical
input -> llm_powered
rule_based -> pipeline
statistical -> pipeline
llm_powered -> pipeline
pipeline -> output: "within budget"
pipeline -> condensation: "needs compression" {
  style.stroke-dash: 3
}
condensation -> input: "next step re-processes" {
  style.stroke: "#dc2626"
  style.stroke-dash: 3
}
