direction: down

title: "Skills System: Agents Teaching Agents" {
  style.font-size: 24
  near: top-center
}

task: "Agent Completes Task" {
  style.fill: "#fefce8"
  style.stroke: "#d97706"

  agent: "Browser Agent" {
    style.fill: "#d97706"
    style.font-color: "#fff"
    label: "Agent runs task\n(e.g. book a flight on Kayak)"
  }
  traj: "Full Trajectory" {
    style.fill: "#f59e0b"
    style.font-color: "#fff"
    label: "Full Trajectory\n(15 steps recorded)"
  }

  agent -> traj
}

extract: "Skill Extraction" {
  style.fill: "#f0fdf4"
  style.stroke: "#16a34a"

  review: "Trajectory Review" {
    style.fill: "#16a34a"
    style.font-color: "#fff"
    label: "LLM Review\n('What would someone need\nto do this in 1-3 steps?')"
  }
  pii: "PII Gate" {
    style.fill: "#059669"
    style.font-color: "#fff"
    label: "PII Gate\n(LLM pass rejects emails,\ntokens, user data)"
  }

  review -> pii
}

task.traj -> extract.review

store: "Skill Store" {
  style.fill: "#ecfdf5"
  style.stroke: "#059669"
  style.bold: true

  skill: "Stored Skill" {
    style.fill: "#10b981"
    style.font-color: "#fff"
    label: "Skill\n(URL pattern + recipe +\nsteps saved)"
  }
}

extract.pii -> store.skill: clean skill

reuse: "Future Agent Reuse" {
  style.fill: "#faf5ff"
  style.stroke: "#7c3aed"

  match: "URL Pattern Match" {
    style.fill: "#7c3aed"
    style.font-color: "#fff"
    label: "New agent hits same site\n(URL pattern matches)"
  }
  fast: "Fast Execution" {
    style.fill: "#8b5cf6"
    style.font-color: "#fff"
    label: "1-3 steps instead of 15\n(skill-guided)"
  }
  feedback: "Feedback" {
    style.fill: "#a855f7"
    style.font-color: "#fff"
    label: "+1 or -1\n(with written reason)"
  }

  match -> fast: apply skill
  fast -> feedback: rate outcome
}

store.skill -> reuse.match: shared across users

feedback_loop: "Skill Lifecycle" {
  style.fill: "#ecfeff"
  style.stroke: "#0891b2"

  edit: "Score drops? Edit skill" {
    style.fill: "#0891b2"
    style.font-color: "#fff"
  }
  retire: "Score < -3? Retire" {
    style.fill: "#06b6d4"
    style.font-color: "#fff"
  }
  merge: "Near-dupes? Auto-merge" {
    style.fill: "#22d3ee"
    style.font-color: "#fff"
  }
}

reuse.feedback -> feedback_loop.edit
reuse.feedback -> feedback_loop.retire
feedback_loop.edit -> store.skill: updated
