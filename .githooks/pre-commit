#!/usr/bin/env python
"""Pre-commit hook: reject commits with emoji in README files."""
import re, sys, subprocess

emoji_pattern = re.compile('[\U0001F300-\U0001F9FF\U00002702-\U000027B0\U0001FA00-\U0001FA6F\U0001FA70-\U0001FAFF\U00002600-\U000026FF\U0001F000-\U0001F02F]')

result = subprocess.run(['git', 'diff', '--cached', '--name-only'], capture_output=True, text=True)
files = [f for f in result.stdout.strip().split('\n') if f.endswith('.md')]

found = False
for filepath in files:
    try:
        with open(filepath, 'r', encoding='utf-8') as f:
            for i, line in enumerate(f, 1):
                matches = emoji_pattern.findall(line)
                if matches:
                    print(f"BLOCKED: {filepath}:{i} contains emoji: {matches}")
                    found = True
    except FileNotFoundError:
        pass

if found:
    print("\nEmoji detected in markdown files. Remove them before committing.")
    print("Rule: No emoji in any .md file. Professional tone only.")
    sys.exit(1)
